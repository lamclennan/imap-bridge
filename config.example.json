{
  "debug": false,

  "sync": {
    "max_dest_attempts":       8,
    "max_msg_attempts":        5,
    "dedup_cache_ttl_hours":   24,
    "backoff_base_seconds":    1,
    "backoff_max_seconds":     60,
    "daily_retry_hour":        7,
    "max_error_retention_days": 0
  },

  "destination": {
    "host":         "imap.gmail.com:993",
    "user":         "archive@gmail.com",
    "security":     "ssl",
    "provider":     "gmail",
    "credentials_file": "keys/client_secret_archive.json",
    "token_file":   "tokens/token_archive.json",
    "report_label": "Bridge/Reports"
  },

  "sources": [
    {
      "host":         "imap-mail.outlook.com:993",
      "user":         "you@outlook.com",
      "pass":         "app-password-here",
      "security":     "ssl",
      "retention_days": 0,
      "sync_new_only": true,
      "mappings": [
        { "from": "INBOX", "to": ["INBOX"] }
      ]
    },
    {
      "host":         "imap.gmail.com:993",
      "user":         "another@gmail.com",
      "security":     "ssl",
      "provider":     "gmail",
      "credentials_file": "keys/client_secret_another.json",
      "token_file":   "tokens/token_another.json",
      "retention_days": -1,
      "sync_new_only": true,
      "mappings": [
        { "from": "INBOX", "to": ["INBOX"] }
      ]
    }
  ]
}
